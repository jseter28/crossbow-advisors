# ============================================================
#  Crossbow Capital Advisors — Apache config (GoDaddy cPanel)
# ============================================================

Options -Indexes
RewriteEngine On

# --- Canonical host: force HTTPS + non-www (https://crossbowadvisors.net) ---
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://crossbowadvisors.net%{REQUEST_URI} [L,R=301]

# --- Pretty URLs ---
# Send /index and /index.html to the root
RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
RewriteRule ^ / [L,R=301]

# 301 any explicit .html request to its extensionless form (de-dupe for SEO)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [L,R=301]

# Internally serve the matching .html file for an extensionless request
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# --- Performance ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain \
    application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css            "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg          "access plus 1 year"
  ExpiresByType image/svg+xml       "access plus 1 year"
  ExpiresByType image/x-icon        "access plus 1 year"
  ExpiresByType text/html           "access plus 1 hour"
</IfModule>

# --- Security headers (lightweight) ---
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
